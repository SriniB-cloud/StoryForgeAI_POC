    "ac_t.add_column('Acceptance Criterion')\n",
    "for ac in parsed_spec['acceptance_criteria']:\n",
    "    ac_t.add_row(ac['id'], ac['text'])\n",
    "console.print(ac_t)\n",
    "\n",
