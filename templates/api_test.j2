    }

    private String paymentPayload(boolean valid) {
        if (valid) {
            return "{\"cardNumber\": \"{{ test_data.card_number }}\", \"expiry\": \"{{ test_data.card_expiry }}\", \"cvv\": \"{{ test_data.card_cvv }}\", \"amount\": 999.99}";
